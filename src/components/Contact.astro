---
---
<section id="contato" class="py-24 md:py-32 relative">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-20 items-stretch">
      <!-- Info Col -->
      <div class="space-y-12 reveal">
        <div class="space-y-4">
          <div class="text-primary font-black uppercase tracking-[0.2em] text-xs">Atendimento Personalizado</div>
          <h2 class="text-blue-950">
            Vamos iniciar sua <br>
            <span class="text-primary italic font-medium">jornada de sucesso?</span>
          </h2>
          <p class="text-lg text-slate-500 max-w-md leading-relaxed">
            Escolha o canal de sua preferência. Estou pronto para te ajudar a conquistar sua melhor comunicação.
          </p>
        </div>

        <!-- Contact Cards -->
        <div class="space-y-6">
          <a href="https://wa.me/seu-numero" class="flex items-center gap-6 p-6 bg-white rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all group">
            <div class="w-14 h-14 bg-green-500/10 text-green-600 rounded-2xl flex items-center justify-center group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.438 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.631 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </div>
            <div>
              <p class="text-xs uppercase font-black tracking-widest text-slate-400 mb-1">Dúvidas rápidas</p>
              <p class="text-lg font-bold text-blue-950">(00) 00000-0000</p>
            </div>
          </a>

          <div class="flex items-center gap-6 p-6 bg-white rounded-[2rem] border border-slate-100 shadow-sm transition-all group">
            <div class="w-14 h-14 bg-primary/10 text-primary rounded-2xl flex items-center justify-center">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <p class="text-xs uppercase font-black tracking-widest text-slate-400 mb-1">Localização</p>
              <p class="text-lg font-bold text-blue-950">Rua Exemplo, 123 - Sala 45</p>
              <p class="text-xs text-slate-500">Centro, Rio de Janeiro - RJ</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Col -->
      <div class="reveal" style="animation-delay: 0.3s;">
        <div class="bg-blue-950 p-10 md:p-14 rounded-[3.5rem] shadow-2xl relative overflow-hidden group">
          <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/20 rounded-full blur-[100px] pointer-events-none"></div>
          
          <form class="space-y-6 relative z-10">
            <div class="space-y-2">
              <label class="text-xs font-black uppercase tracking-[0.2em] text-blue-200/60 ml-2">Qual seu nome?</label>
              <input type="text" placeholder="Ex: Maria Silva" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white placeholder:text-white/20 focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-all">
            </div>

            <div class="space-y-2">
              <label class="text-xs font-black uppercase tracking-[0.2em] text-blue-200/60 ml-2">Melhor E-mail</label>
              <input type="email" placeholder="maria@exemplo.com" class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white placeholder:text-white/20 focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-all">
            </div>

            <div class="space-y-2">
              <label class="text-xs font-black uppercase tracking-[0.2em] text-blue-200/60 ml-2">Como posso te ajudar?</label>
              <textarea rows="4" placeholder="Conte resumidamente seu caso..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white placeholder:text-white/20 focus:outline-none focus:border-primary/50 focus:bg-white/10 transition-all resize-none"></textarea>
            </div>

            <button type="submit" class="btn-primary w-full !text-blue-950 !bg-white hover:!bg-slate-50 shadow-none hover:shadow-2xl">Enviar Mensagem</button>
            <p class="text-center text-[10px] text-blue-200/30 uppercase tracking-widest font-black">Resposta em até 24h úteis</p>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
