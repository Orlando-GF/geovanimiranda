---
---
<section id="contato" class="max-w-7xl mx-auto px-6 py-16 md:py-24">
  <div class="bg-blue-950 rounded-[3rem] overflow-hidden relative shadow-2xl">
    <!-- Background Patterns -->
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute -top-1/2 -left-1/4 w-full h-full bg-primary rounded-full blur-[120px]"></div>
      <div class="absolute -bottom-1/2 -right-1/4 w-full h-full bg-blue-400 rounded-full blur-[120px]"></div>
    </div>

    <div class="relative grid md:grid-cols-2">
      <!-- Info Side -->
      <div class="p-8 md:p-16 space-y-12">
        <div class="space-y-6">
          <h2 class="text-3xl md:text-5xl text-white">Pronto para começar sua <span class="text-blue-400">evolução?</span></h2>
          <p class="text-blue-100 text-lg opacity-80 leading-relaxed">
            Agende uma avaliação inicial e descubra como a fonoaudiologia pode transformar sua vida. Atendimento presencial e online.
          </p>
        </div>

        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-blue-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <div>
              <p class="text-[10px] text-blue-400 uppercase font-bold tracking-widest">WhatsApp</p>
              <p class="text-white font-bold">(xx) xxxxx-xxxx</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-blue-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <p class="text-[10px] text-blue-400 uppercase font-bold tracking-widest">Localização</p>
              <p class="text-white font-bold">Consulte endereços de atendimento fixo</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form Side -->
      <div class="bg-white/5 p-8 md:p-16 backdrop-blur-sm border-l border-white/10">
        <form class="space-y-6">
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold text-blue-300 uppercase tracking-widest">Nome Completo</label>
              <input type="text" placeholder="Seu nome" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder:text-blue-200/30 focus:outline-none focus:border-primary transition-colors">
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-blue-300 uppercase tracking-widest">WhatsApp</label>
              <input type="tel" placeholder="(00) 00000-0000" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder:text-blue-200/30 focus:outline-none focus:border-primary transition-colors">
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-blue-300 uppercase tracking-widest">Assunto de interesse</label>
            <select class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-primary transition-colors appearance-none">
              <option class="bg-blue-900">Selecione uma opção</option>
              <option class="bg-blue-900">Fonoaudiologia Infantil</option>
              <option class="bg-blue-900">Terapia para Adultos</option>
              <option class="bg-blue-900">Reabilitação Vocal</option>
              <option class="bg-blue-900">Outros</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold text-blue-300 uppercase tracking-widest">Mensagem</label>
            <textarea rows="4" placeholder="Como posso te ajudar?" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-3 text-white placeholder:text-blue-200/30 focus:outline-none focus:border-primary transition-colors resize-none"></textarea>
          </div>
          <button type="submit" class="btn-primary w-full shadow-2xl">Enviar Solicitação</button>
        </form>
      </div>
    </div>
  </div>
</section>
