---
const alerts = [
  {
    title: "Atraso na Fala",
    desc: "Crianças que demoram a falar as primeiras palavras ou frases simples.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    color: "bg-blue-50"
  },
  {
    title: "Dificuldade na Escrita",
    desc: "Trocas de letras ou dificuldades extremas na alfabetização escolar.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>`,
    color: "bg-orange-50"
  },
  {
    title: "Rouquidão Frequente",
    desc: "Cansaço vocal ou falhas na voz após o uso prolongado no dia a dia.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>`,
    color: "bg-green-50"
  },
  {
    title: "Respirador Bucal",
    desc: "Dormir de boca aberta ou apresentar cansaço frequente ao falar.",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.871 4.871a1 1 0 011.415 0L12 10.585l5.713-5.714a1 1 0 111.414 1.414L13.414 12l5.713 5.713a1 1 0 11-1.414 1.415L12 13.414l-5.714 5.713a1 1 0 01-1.415-1.414L10.585 12 4.871 6.287a1 1 0 010-1.415z" /></svg>`,
    color: "bg-purple-50"
  }
];
---
<section id="alertas" class="py-24 bg-lux-gradient relative overflow-visible">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Header -->
    <div class="text-center space-y-4 mb-20 reveal">
      <div class="text-primary font-black uppercase tracking-[0.2em] text-xs">Sinais de Atenção</div>
      <h2 class="text-blue-950">
        Quando buscar um <span class="italic font-medium text-primary">especialista?</span>
      </h2>
      <p class="text-slate-500 max-w-2xl mx-auto text-lg">
        Fique atento aos pequenos sinais. O diagnóstico precoce é fundamental para um tratamento rápido e eficiente.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {alerts.map((alert, index) => (
        <div 
          class="card-premium reveal group" 
          style={`animation-delay: ${0.1 * (index + 1)}s`}
        >
          <div class={`w-14 h-14 ${alert.color} rounded-2xl flex items-center justify-center text-blue-950 mb-8 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500 shadow-sm border border-black/5`}>
            <Fragment set:html={alert.icon} />
          </div>
          <h3 class="text-xl font-bold text-blue-950 mb-3 tracking-tight group-hover:text-primary transition-colors">{alert.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed italic opacity-80 group-hover:opacity-100 transition-opacity">
            {alert.desc}
          </p>
          
          <!-- Bottom Indicator -->
          <div class="mt-8 h-1 w-0 bg-primary group-hover:w-full transition-all duration-700"></div>
        </div>
      ))}
    </div>
    
    <!-- Info Note -->
    <div class="mt-20 p-8 flex flex-col md:flex-row items-center gap-8 bg-white/50 backdrop-blur-sm rounded-[3rem] border border-white/20 shadow-sm reveal" style="animation-delay: 0.6s;">
      <div class="w-16 h-16 bg-blue-950/5 rounded-full flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-blue-950" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <p class="text-slate-600 italic text-center md:text-left leading-relaxed">
        <strong>Atenção:</strong> Estes são apenas alguns indicadores comuns. Se você percebe qualquer desconforto ou alteração na comunicação ou audição, agende uma avaliação profissional.
      </p>
      <a href="#contato" class="btn-primary !px-6 !py-3 !text-sm whitespace-nowrap">Agendar Avaliação</a>
    </div>
  </div>
</section>
