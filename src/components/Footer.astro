---
---
<footer class="bg-white pt-24 pb-12 border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-16 mb-20">
      <!-- Info -->
      <div class="col-span-1 md:col-span-2 space-y-8">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg shadow-primary/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-heading font-bold text-blue-950 text-lg tracking-tighter leading-none">Geovani Miranda</span>
            <span class="text-[8px] uppercase tracking-[0.3em] font-black text-primary mt-1">Fonoaudiólogo</span>
          </div>
        </a>
        <p class="text-slate-500 max-w-sm leading-relaxed italic">
          Transformando a comunicação em uma ferramenta de conexão, saúde e sucesso pessoal. Atendimento ético e especializado para todas as idades.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-blue-950 hover:bg-primary hover:text-white transition-all shadow-sm">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-blue-950 hover:bg-primary hover:text-white transition-all shadow-sm">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12s.014 3.667.072 4.947c.2 4.352 2.612 6.772 6.972 6.972 1.28.058 1.688.072 4.948.072s3.667-.014 4.947-.072c4.351-.2 6.772-2.612 6.972-6.972.058-1.28.072-1.688.072-4.948s-.014-3.667-.072-4.947c-.2-4.352-2.612-6.772-6.972-6.972C15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="space-y-8">
        <h4 class="text-blue-950 font-bold uppercase tracking-widest text-[11px]">Navegação</h4>
        <ul class="space-y-4 text-slate-500 font-medium">
          <li><a href="#sobre" class="hover:text-primary transition-colors">Sobre Mim</a></li>
          <li><a href="#servicos" class="hover:text-primary transition-colors">Especialidades</a></li>
          <li><a href="#depoimentos" class="hover:text-primary transition-colors">Depoimentos</a></li>
          <li><a href="#contato" class="hover:text-primary transition-colors">Agendamento</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="space-y-8">
        <h4 class="text-blue-950 font-bold uppercase tracking-widest text-[11px]">Contato</h4>
        <ul class="space-y-4 text-slate-500 font-medium">
          <li class="flex items-center gap-3">
             <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
             (00) 00000-0000
          </li>
          <li class="flex items-center gap-3">
             <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
             Rio de Janeiro, RJ
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-12 border-t border-slate-50 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-slate-400 text-xs font-medium">
        © 2024 Geovani Miranda. Todos os direitos reservados.
      </p>
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-black uppercase tracking-widest text-slate-300">Desenvolvido com</span>
        <div class="inline-flex items-center gap-1 bg-slate-50 px-2 py-1 rounded-md">
           <span class="text-[10px] font-bold text-primary">Astro</span>
        </div>
      </div>
    </div>
  </div>
</footer>
