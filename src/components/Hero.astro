---
---
<div class="w-full relative overflow-visible">
  <!-- Top Glow (Anti-Wall) -->
  <div class="absolute -top-24 left-1/2 -translate-x-1/2 w-full max-w-4xl h-64 bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>

  <section class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 lg:gap-20 items-center pt-24 pb-16 md:pt-40 md:pb-24 relative">
    <!-- Texto (Primeiro no Mobile) -->
    <div class="order-1 md:order-1 space-y-8 reveal">
      <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-bold tracking-widest uppercase">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
        </span>
        Atendimento Presencial e Online
      </div>
      
      <div class="space-y-4">
        <h1 class="reveal" style="animation-delay: 0.1s;">
          Recupere sua <br>
          <span class="text-primary italic font-medium">comunicação</span> <br> 
          & qualidade de vida
        </h1>
        
        <p class="text-lg md:text-xl text-slate-500 max-w-xl leading-relaxed reveal" style="animation-delay: 0.2s;">
          Tratamento fonoaudiológico especializado para crianças, adultos e idosos. Tecnologia e humanização para transformar sua voz e fala.
        </p>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 pt-4 reveal" style="animation-delay: 0.3s;">
        <a href="#agendamento" class="btn-primary text-center">Agendar Avaliação</a>
        <a href="https://wa.me/seu-numero" class="btn-secondary btn-whatsapp-glow flex items-center justify-center gap-3 group" target="_blank">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.438 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.631 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Falar no WhatsApp
        </a>
      </div>
    </div>

    <!-- Imagem e Efeitos -->
    <div class="order-2 md:order-2 relative reveal" style="animation-delay: 0.4s;">
      <!-- Decorative background elements -->
      <div class="absolute -top-10 -right-10 md:-top-1/4 md:-right-1/4 w-64 h-64 md:w-[150%] md:h-[150%] bg-primary/10 rounded-full blur-[100px] md:blur-[150px] pointer-events-none opacity-60"></div>
      <div class="absolute -bottom-10 -left-10 md:-bottom-1/4 md:-left-1/4 w-64 h-64 md:w-[120%] md:h-[120%] bg-green-500/5 rounded-full blur-[80px] md:blur-[120px] pointer-events-none opacity-40"></div>
      
      <div class="relative bg-lux-gradient rounded-[2.5rem] aspect-[4/5] max-h-[400px] md:max-h-none overflow-hidden shadow-2xl border-[12px] border-white active:scale-[0.99] transition-transform duration-500 group">
        <!-- Placeholder for Photo -->
        <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-300 gap-4 bg-slate-50/50 backdrop-blur-[2px]">
          <svg class="w-16 h-16 opacity-10 group-hover:scale-110 transition-transform duration-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <span class="text-[10px] font-bold uppercase tracking-[0.3em] opacity-30">Portrait Premium</span>
        </div>
        
        <!-- Subtle Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-blue-950/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
      </div>

      <!-- Trust floating card -->
      <div class="absolute -bottom-4 -left-4 md:bottom-10 md:-left-10 bg-white/90 backdrop-blur-md p-5 rounded-[2rem] shadow-2xl border border-white flex items-center gap-5 animate-bounce-slow">
        <div class="w-14 h-14 bg-primary rounded-2xl flex items-center justify-center text-white shadow-lg shadow-primary/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-2xl font-bold text-blue-950 tracking-tighter">+500</p>
          <p class="text-[9px] text-slate-500 uppercase font-black tracking-[0.2em]">Pacientes Felizes</p>
        </div>
      </div>
    </div>
  </section>
</div>
