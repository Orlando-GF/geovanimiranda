<section class="max-w-7xl mx-auto px-6 py-16 md:py-24">
  <div class="bg-blue-950 rounded-[3rem] p-12 md:p-24 text-center text-white relative overflow-hidden shadow-2xl">
    <!-- Background Decoration -->
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-white/10 rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-primary/20 rounded-full blur-[100px] pointer-events-none"></div>
    
    <div class="relative z-10 space-y-8">
      <h2 class="text-3xl md:text-6xl font-bold leading-tight text-white mb-2">
        Não espere mais para<br>cuidar da sua <span class="text-blue-400 italic font-medium">comunicação</span>
      </h2>
      <p class="text-blue-50 text-lg md:text-xl max-w-2xl mx-auto opacity-90 leading-relaxed">
        Agende uma avaliação completa e descubra como a fonoaudiologia pode transformar sua qualidade de vida.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-6 justify-center pt-4">
        <a href="#agendamento" class="bg-white text-blue-950 px-10 py-5 rounded-2xl font-bold text-xl hover:bg-slate-50 transition-all shadow-xl hover:-translate-y-1">
          Quero agendar agora
        </a>
        <a href="https://wa.me/seu-numero" class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-10 py-5 rounded-2xl font-bold text-xl hover:bg-white/20 transition-all hover:scale-[1.02]">
          Dúvidas? Chamar no Zap
        </a>
      </div>
    </div>
  </div>
</section>
