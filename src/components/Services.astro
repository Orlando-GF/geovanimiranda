---
const services = [
  {
    title: "Voz e Oratória",
    desc: "Aprimoramento da voz para profissionais que dependem da comunicação clara.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg>`,
    special: "Executive"
  },
  {
    title: "Fala e Linguagem",
    desc: "Tratamento especializado para trocas na fala e atrasos de desenvolvimento.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" /></svg>`,
    special: "Kids & Adults"
  },
  {
    title: "Motricidade Orofacial",
    desc: "Reabilitação das funções de mastigação, respiração e deglutição.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.871 4.871a1 1 0 011.415 0L12 10.585l5.713-5.714a1 1 0 111.414 1.414L13.414 12l5.713 5.713a1 1 0 11-1.414 1.415L12 13.414l-5.714 5.713a1 1 0 01-1.415-1.414L10.585 12 4.871 6.287a1 1 0 010-1.415z" /></svg>`,
    special: "Funcional"
  }
];
---
<section id="servicos" class="py-24 md:py-32 relative">
  <!-- Subtle gradient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-4xl h-full bg-primary/5 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-10 mb-20 reveal">
      <div class="space-y-4">
        <div class="text-primary font-black uppercase tracking-[0.2em] text-xs">Especialidades Clínicas</div>
        <h2 class="text-blue-950 mb-0">
          Tratamentos de <br>
          <span class="text-primary italic font-medium">alta performance</span>
        </h2>
      </div>
      <p class="text-slate-500 max-w-md text-lg leading-relaxed italic border-l-4 border-primary/20 pl-8">
        Nossas especializações são voltadas para transformar a comunicação em uma ferramenta de sucesso e bem-estar.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-3 gap-10">
      {services.map((service, index) => (
        <div 
          class="card-premium reveal group" 
          style={`animation-delay: ${0.2 * (index + 1)}s`}
        >
          <div class="flex flex-col h-full">
            <div class="mb-8 flex justify-between items-start">
              <div class="w-16 h-16 bg-blue-950 text-white rounded-[1.5rem] flex items-center justify-center shadow-xl shadow-blue-950/20 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                <Fragment set:html={service.icon} />
              </div>
              <span class="text-[10px] font-black uppercase tracking-widest text-primary bg-primary/10 px-3 py-1 rounded-full">
                {service.special}
              </span>
            </div>
            
            <h3 class="text-2xl font-bold text-blue-950 mb-4 tracking-tighter group-hover:text-primary transition-colors">{service.title}</h3>
            <p class="text-slate-500 leading-relaxed mb-auto">
              {service.desc}
            </p>
            
            <div class="mt-10 flex items-center gap-2 text-primary font-bold text-sm group-hover:gap-4 transition-all">
              <span>Saiba mais</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Box -->
    <div class="mt-20 reveal" style="animation-delay: 0.8s;">
      <div class="bg-blue-950 p-12 rounded-[3.5rem] flex flex-col md:flex-row items-center justify-between gap-10 shadow-2xl relative overflow-hidden group">
        <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-10 transition-opacity duration-700"></div>
        
        <div class="space-y-4 relative z-10 text-center md:text-left">
          <h3 class="text-white text-3xl tracking-tighter mb-0">Precisando de um fonoaudiólogo?</h3>
          <p class="text-blue-100/60 font-medium italic">Agende uma conversa e tire suas dúvidas agora mesmo.</p>
        </div>
        
        <div class="flex gap-4 relative z-10">
          <a href="#contato" class="bg-white text-blue-950 px-8 py-4 rounded-2xl font-bold hover:bg-slate-50 transition-all shadow-xl hover:-translate-y-1">Falar com Geovani</a>
        </div>
      </div>
    </div>
  </div>
</section>
