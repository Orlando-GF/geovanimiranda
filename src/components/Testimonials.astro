---
const testimonials = [
  {
    name: "Ana Claudia",
    role: "Mãe do Pedro (6 anos)",
    quote: "A evolução do Pedro foi nítida em poucos meses. O Geovani tem um jeito especial com as crianças que torna a terapia muito leve.",
    rating: 5
  },
  {
    name: "Ricardo Santos",
    role: "Executivo de Vendas",
    quote: "Minha oratória mudou completamente. Hoje me sinto muito mais seguro para liderar reuniões e apresentações importantes.",
    rating: 5
  },
  {
    name: "Dona Maria",
    role: "Paciente de Reabilitação",
    quote: "O carinho e a paciência no tratamento da minha deglutição foram fundamentais para minha recuperação total.",
    rating: 5
  }
];
---
<section id="depoimentos" class="py-24 md:py-32 bg-slate-50 relative overflow-hidden">
  <!-- Decorative text background -->
  <div class="absolute top-10 right-0 text-[15rem] font-black text-slate-200/40 select-none pointer-events-none transform translate-x-1/2">"</div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-20 reveal">
      <div class="text-primary font-black uppercase tracking-[0.2em] text-xs">Vidas Transformadas</div>
      <h2 class="text-blue-950">
        O que dizem nossos <span class="italic font-medium text-primary">pacientes</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-10">
      {testimonials.map((t, index) => (
        <div 
          class="bg-white p-10 rounded-[3rem] shadow-[0_4px_25px_rgba(0,0,0,0.03)] border border-slate-100 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 reveal group"
          style={`animation-delay: ${index * 0.2}s`}
        >
          <!-- Stars -->
          <div class="flex gap-1 mb-8">
            {[...Array(t.rating)].map(() => (
              <svg class="w-4 h-4 text-orange-400 fill-current group-hover:scale-110 transition-transform" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="text-lg text-slate-600 italic leading-relaxed mb-8 relative">
            <span class="text-3xl text-primary/20 absolute -top-4 -left-4">"</span>
            {t.quote}
          </p>

          <div class="flex items-center gap-4 border-t border-slate-50 pt-8">
            <div class="w-12 h-12 bg-slate-100 rounded-2xl flex items-center justify-center text-slate-400 overflow-hidden">
               <svg class="w-8 h-8 opacity-20" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            </div>
            <div>
              <p class="font-bold text-blue-950 tracking-tight">{t.name}</p>
              <p class="text-[10px] uppercase font-black tracking-widest text-primary/70">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
